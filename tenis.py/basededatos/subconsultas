SELECT nombre FROM empleados
WHERE salario(AVG(salario) FROM empleados);

SELECT *
FROM empleados e
WHERE salario > (
    SELECT AVG(salario)
    FROM empleados
    WHERE id_departamento = e.id_departamento
);

SELECT e.*
FROM empleados e
JOIN (
    SELECT id_departamento, AVG(salario) AS salario_promedio
    FROM empleados
    GROUP BY id_departamento
) p
ON e.id_departamento = p.id_departamento
WHERE e.salario > p.salario_promedio;

SELECT d.nombre_departamento
FROM departamentos d
JOIN (
    SELECT id_departamento, AVG(salario) AS salario_promedio
    FROM empleados
    GROUP BY id_departamento
    ORDER BY salario_promedio DESC
    LIMIT 1
) p
ON d.id_departamento = p.id_departamento;

SELECT *
FROM departamentos d
WHERE NOT EXISTS (
    SELECT 1
    FROM empleados e
    WHERE e.id_departamento = d.id_departamento
);
