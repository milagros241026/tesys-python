REATE TABLE departamentos (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(50) NOT NULL
);

CREATE TABLE empleados (
    id SERIAL PRIMARY KEY,
    nombre VARCHAR(50),
    apellido VARCHAR(50),
    salario NUMERIC(10,2),
    id_departamento INTEGER REFERENCES departamentos(id),
    fecha_ingreso DATE
);

